{
  "manifest_version": 3,
  "name": "Bookmark Manager",
  "version": "0.1.0",
  "description": "AI-powered bookmark manager with tag-based organization.",

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidebar/index.html"
  },

  "action": {
    "default_title": "Open Bookmark Manager"
  }
}
