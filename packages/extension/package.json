{
  "name": "@bookmark-manager/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:firefox": "vite build --mode firefox",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build && npm run build:firefox",
    "test": "vitest run"
  },
  "dependencies": {
    "@bookmark-manager/shared": "*",
    "i18next": "^26.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.5.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
