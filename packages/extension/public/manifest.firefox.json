{
  "manifest_version": 3,
  "name": "Bookmark Manager",
  "version": "0.1.0",
  "description": "AI-powered bookmark manager with tag-based organization.",

  "browser_specific_settings": {
    "gecko": {
      "id": "bookmark-manager@nevadah",
      "strict_min_version": "128.0"
    }
  },

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "bookmarks",
    "alarms"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
      "scripts": ["background/index.js"]
  },

  "sidebar_action": {
    "default_panel": "sidebar/index.html",
    "default_title": "Bookmark Manager"
  },

  "action": {
    "default_title": "Open Bookmark Manager"
  }
}
